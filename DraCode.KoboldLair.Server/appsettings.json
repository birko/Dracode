{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "DraCode.KoboldLair": "Information",
      "DraCode.KoboldLair.Services": "Information",
      "DraCode.KoboldLair.Factories": "Information",
      "DraCode.KoboldLair.Agents": "Debug",
      "DraCode.Agent": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.AspNetCore.WebSockets": "Information",
      "System.Net.WebSockets": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Authentication": {
    "Enabled": false,
    "Tokens": [],
    "TokenBindings": [],
    "Jwt": {
      "Enabled": false,
      "Secret": "${KOBOLDLAIR_JWT_SECRET}",
      "Issuer": "KoboldLair",
      "Audience": "KoboldLair",
      "ExpirationMinutes": 60,
      "RefreshExpirationDays": 7,
      "Users": []
    }
  },
  "KoboldLair": {
    "DefaultProvider": "",
    "ProjectsPath": "./projects",
    "Data": {
      "DefaultBackend": "SqLite",
      "SqLitePath": "koboldlair.db"
    },
    "Limits": {
      "MaxParallelKobolds": 1,
      "MaxParallelDrakes": 1,
      "MaxParallelWyrms": 1,
      "MaxParallelWyverns": 1,
      "MonitoringIntervalSeconds": 60,
      "StuckKoboldTimeoutMinutes": 60
    },
    "Providers": [],
    "Planning": {
      "Enabled": true,
      "MaxPlanningIterations": 5,
      "SavePlanProgress": true,
      "ResumeFromPlan": true,
      "UseEnhancedExecution": true,
      "UseProgressiveDetailReveal": true,
      "MediumDetailStepCount": 2,
      "ExecutionMode": "multi-step",
      "AllowPlanModifications": false,
      "AutoApproveModifications": false,
      "MaxParallelSteps": 3,
      "PlanSaveDebounceIntervalMs": 2500
    },
    "Reflection": {
      "Enabled": true,
      "EscalationConfidenceThreshold": 30,
      "StallDetectionCount": 3,
      "MonitorIntervalSeconds": 45,
      "NoProgressTimeoutMinutes": 10,
      "MaxFileWriteRepetitions": 3
    },
    "Iterations": {
      "MaxKoboldIterations": 100,
      "MaxDragonInitialIterations": 15,
      "MaxDragonContinueIterations": 25,
      "MaxWyrmIterations": 8,
      "MaxWyvernIterations": 1,
      "MaxSubAgentIterations": 15
    },
    "Verification": {
      "Enabled": true,
      "TimeoutSeconds": 600,
      "AutoCreateFixTasks": true,
      "RequireAllChecksPassing": false,
      "SkipForImportedProjects": true
    },
    "Messaging": {
      "Enabled": false,
      "Backend": "InMemory",
      "Queues": {
        "TaskAssignment": "kobold.tasks.assign",
        "TaskCompletion": "kobold.tasks.complete",
        "Heartbeat": "kobold.heartbeat"
      }
    },
    "ReasoningMonitor": {
      "Enabled": true,
      "MonitoringIntervalSeconds": 30,
      "DecliningConfidenceCheckpoints": 3,
      "RepeatedFileModificationThreshold": 5,
      "StalledProgressCheckpoints": 3,
      "HighBlockerThreshold": 3,
      "LowConfidenceInterventionThreshold": 30,
      "AutoInterventionEnabled": true,
      "DecliningConfidenceDropThreshold": 20
    },
    "RateLimiting": {
      "Enabled": false,
      "ProviderLimits": []
    },
    "CostTracking": {
      "Enabled": true,
      "Pricing": [],
      "Budget": {
        "DailyBudgetUsd": 0,
        "MonthlyBudgetUsd": 0,
        "ProjectBudgetUsd": 0,
        "WarningThresholdPercent": 80
      }
    }
  }
}